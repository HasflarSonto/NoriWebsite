# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Product ID — different in test vs live mode. Get from Stripe Dashboard → Products.
STRIPE_PRODUCT_ID=prod_...

# Supabase — community signup DB. If you used Vercel's Supabase
# integration, the vars are auto-injected with a DB-name prefix
# (e.g. noril1_SUPABASE_SERVICE_ROLE_KEY). lib/env.ts reads both
# the canonical and prefixed forms.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (confirmation emails)
RESEND_API_KEY=re_...
RESEND_FROM="NORI <preorders@nori.example>"

# Vercel KV (optional; preorders store). Leave blank to skip.
KV_REST_API_URL=
KV_REST_API_TOKEN=
